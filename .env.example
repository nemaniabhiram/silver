# Copy to .env for local development. Every value below is the dev default.

DATABASE_URL=postgres://silver:silver@localhost:5433/silver

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=silver
S3_SECRET_KEY=silver-secret
S3_BUCKET=silver
S3_FORCE_PATH_STYLE=true

DEPLOY_DOMAIN=localhost:4001
DEPLOY_PROTOCOL=http

API_PORT=4000
SERVE_PORT=4001
WEB_ORIGIN=http://localhost:5173
TRUST_PROXY=false

MAX_UPLOAD_MB=50
RATE_LIMIT_DEPLOYS_PER_HOUR=10
RATE_LIMIT_READS_PER_MINUTE=120

POLL_INTERVAL_MS=1500
MAX_CONCURRENT_BUILDS=1
BUILD_TIMEOUT_SECONDS=300
BUILD_MEMORY_MB=1024
BUILD_CPUS=1
MAX_OUTPUT_MB=100
BUILDER_IMAGE=silver-builder:latest

RETENTION_DAYS=7

VITE_API_URL=http://localhost:4000
VITE_MAX_UPLOAD_MB=50
