{
  "name": "silver",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm run build:shared && concurrently -n shared,api,worker,serve,web -c gray,blue,magenta,green,cyan \"pnpm --filter @silver/shared dev\" \"pnpm --filter @silver/api dev\" \"pnpm --filter @silver/worker dev\" \"pnpm --filter @silver/serve dev\" \"pnpm --filter @silver/web dev\"",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @silver/shared build",
    "typecheck": "pnpm run build:shared && pnpm -r typecheck",
    "test": "pnpm -r test",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "fixtures": "node scripts/make-fixtures.mjs",
    "smoke": "node scripts/smoke.mjs",
    "bench": "node scripts/bench.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
